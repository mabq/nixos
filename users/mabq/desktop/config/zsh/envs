# vim: filetype=sh

# Some packages (like zsh-autosuggestions) do not provide an executable, these variables help us reference current system and home links to nix store.
export NIXOS_CURRENTSYSTEM="/run/current-system/sw"
export NIXOS_CURRENTHOME="$HOME/.local/state/home-manager/gcroots/current-home/home-path"

export EDITOR="nvim" # TODO: check uswm later

export BAT_THEME=ansi
export PATH="$NIXOS_USERPROFILEPATH/bin:$PATH:$HOME/.local/bin"
export STARSHIP_CONFIG=${NIXOS_USERPROFILEPATH}/config/starship/starship.toml
export SUDO_EDITOR=$EDITOR

