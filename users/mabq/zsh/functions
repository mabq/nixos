for f in ${NIXOS_CONFIG_PATH}/users/${USER}/zsh/fns/*; do source "$f"; done

function yy() {
  # https://yazi-rs.github.io/docs/quick-start#shell-wrapper
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}
